# Xyra Chat mobile — copy to .env and fill from the web app's values.
# These are PUBLIC client values (same as the web app's NEXT_PUBLIC_* keys) —
# the anon key is safe to ship in the app binary. Do NOT put the service-role
# key or any server secret here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Base URL of the deployed Next.js web app — the mobile app calls its
# /api/channels/*/send endpoints (authenticated with the Supabase JWT) to send.
# Local dev against `npm run dev`: use your machine's LAN IP, e.g.
#   http://192.168.1.20:3000   (NOT localhost — the phone can't reach that)
EXPO_PUBLIC_API_BASE_URL=https://xyra-chat.vercel.app
