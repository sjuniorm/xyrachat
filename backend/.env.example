# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/omnichannel
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# WhatsApp (Meta API)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# Instagram (Meta API)
INSTAGRAM_VERIFY_TOKEN=your-instagram-verify-token
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Facebook Messenger (Meta API)
FACEBOOK_VERIFY_TOKEN=your-facebook-verify-token
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Telegram Bot API
TELEGRAM_SECRET_TOKEN=your-telegram-secret-token

# Storage (S3-compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=omnichannel-media

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@yourdomain.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project

# CORS
CORS_ORIGIN=http://localhost:3000

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here
