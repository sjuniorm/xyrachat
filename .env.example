# Xyra Chat — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog (EU host for GDPR)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta — WhatsApp Cloud API
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string you choose; you paste this
#   into Meta App Dashboard → WhatsApp → Configuration → Webhook → Verify Token.
# META_APP_SECRET: from Meta App Dashboard → Settings → Basic → App secret.
#   Used for X-Hub-Signature-256 verification on every inbound webhook.
#   Same secret is reused for Instagram + Messenger (same Meta app).
# Channel access tokens are NOT in env — they're stored per-channel in
# Supabase Vault, only the vault UUID lives in channels.access_token_vault_id.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Meta — Instagram DM (Week 5)
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN: any random string you choose; pasted into
#   Meta App Dashboard → Webhooks → Instagram → Verify Token. Use a different
#   value from WHATSAPP_WEBHOOK_VERIFY_TOKEN so each can be rotated alone.
# META_APP_ID: Meta App Dashboard → Settings → Basic → App ID. Needed only
#   for the one-click "Continue with Facebook" connect flow. Manual entry
#   still works without it.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
