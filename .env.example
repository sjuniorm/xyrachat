# Xyra Chat — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog (EU host for GDPR)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta — WhatsApp Cloud API
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string you choose; you paste this
#   into Meta App Dashboard → WhatsApp → Configuration → Webhook → Verify Token.
# META_APP_SECRET: from Meta App Dashboard → Settings → Basic → App secret.
#   Used for X-Hub-Signature-256 verification on every inbound webhook.
#   Same secret is reused for Instagram + Messenger (same Meta app).
# Channel access tokens are NOT in env — they're stored per-channel in
# Supabase Vault, only the vault UUID lives in channels.access_token_vault_id.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Meta — Instagram DM (Week 5)
#
# Xyra Chat ships with TWO separate Meta apps:
#   - The original Facebook/Meta app for WhatsApp Cloud API
#     (META_APP_SECRET above + future META_APP_ID for WA Embedded Signup)
#   - An Instagram-specific Meta app called "Xyra Chat-IG"
#     (INSTAGRAM_APP_ID + INSTAGRAM_APP_SECRET here)
#
# Webhook + OAuth secrets are NOT shared between the two — each app has its
# own. So `/api/webhooks/instagram` HMACs against INSTAGRAM_APP_SECRET (NOT
# META_APP_SECRET), and the Continue-with-Facebook OAuth uses INSTAGRAM_APP_ID
# + INSTAGRAM_APP_SECRET.
#
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN: any random string you choose; pasted into
#   Meta App Dashboard → (Xyra Chat-IG) → Webhooks → Instagram → Verify Token.
#   Keep distinct from WHATSAPP_WEBHOOK_VERIFY_TOKEN.
# INSTAGRAM_APP_ID / INSTAGRAM_APP_SECRET: Meta App Dashboard → (Xyra Chat-IG)
#   → Settings → Basic. Used for the Continue-with-Facebook OAuth flow AND
#   for verifying X-Hub-Signature-256 on inbound Instagram webhooks.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# META_APP_ID: Meta App Dashboard → (original Meta app) → Settings → Basic
#   → App ID. Reserved for future WhatsApp Embedded Signup (Week 9). Not
#   used today.
META_APP_ID=

# WhatsApp Embedded Signup (one-click connect). When BOTH are set, the WA
# connect screen shows a "Connect with WhatsApp" button (Meta's Embedded Signup)
# instead of manual-entry only. Both are PUBLIC (baked into the client bundle).
# NEXT_PUBLIC_META_APP_ID = the original Meta app's App ID.
# NEXT_PUBLIC_WHATSAPP_ES_CONFIG_ID = the Embedded Signup configuration ID from
#   Meta App Dashboard → WhatsApp → Embedded Signup → Configurations.
# The server-side code exchange uses META_APP_ID + META_APP_SECRET (above).
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_WHATSAPP_ES_CONFIG_ID=
# Messenger one-click connect (Facebook Login for Business). When set (together
# with NEXT_PUBLIC_META_APP_ID), the Messenger connect screen shows a "Continue
# with Facebook" button. Public. From Meta App Dashboard → Facebook Login for
# Business → Configurations (with pages_messaging + pages_show_list +
# pages_manage_metadata).
NEXT_PUBLIC_MESSENGER_OAUTH_CONFIG_ID=

# MESSENGER_WEBHOOK_VERIFY_TOKEN: any random string you choose; pasted into
#   Meta App Dashboard → (original Meta app) → Webhooks → Messenger → Verify
#   Token. Facebook Messenger is a product on the ORIGINAL Meta app (same app
#   as WhatsApp), so `/api/webhooks/messenger` HMACs against META_APP_SECRET
#   (NOT a Messenger-specific secret). Keep this verify token distinct from the
#   WhatsApp + Instagram ones so each can be rotated independently.
MESSENGER_WEBHOOK_VERIFY_TOKEN=

# Email (Resend Inbound + outbound) — Week 6
# RESEND_API_KEY: Resend Dashboard → API Keys. Used for BOTH inbound
#   webhook verification (looking up the workspace) and outbound sends.
# RESEND_WEBHOOK_SECRET: Resend Dashboard → Webhooks → (your inbound webhook)
#   → Signing Secret. Comes in `whsec_<base64>` form. We strip the prefix
#   and HMAC-SHA256 against the Svix-format signature header.
# INBOUND_EMAIL_DOMAIN: domain customers email — e.g. `mail.xyrachat.com`.
#   Must be a Resend-verified domain with MX records pointing at Resend.
#   Each Email channel gets a local-part on this domain (e.g.
#   `<slug>@mail.xyrachat.com`).
# EMAIL_FROM_ADDRESS: optional fallback `From:` for outbound when an Email
#   channel doesn't have its own inbox_email. Defaults to
#   `support@xyrachat.com` in code.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=mail.xyrachat.com
EMAIL_FROM_ADDRESS=support@xyrachat.com

# AI — Week 7
# ANTHROPIC_API_KEY: Anthropic Console → API Keys. Used for:
#   - Bot chat replies (claude-sonnet-4-6) via /api/ai/suggest-reply +
#     webhook bot-gate
#   - Message Assist rewrites (claude-haiku-4-5-20251001) via
#     /api/ai/message-assist
#   - Translate-inbound + auto-translate (claude-haiku)
# OPENAI_API_KEY: OpenAI Dashboard → API Keys. Used for:
#   - Embeddings for the RAG knowledge base
#     (text-embedding-3-small, 1536 dims — must match vector(1536)
#     in migration 016)
#   - Future: Whisper voice-note transcription (whisper-1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Broadcasts — Week 9
# CRON_SECRET: long random string. Sent as `Authorization: Bearer <value>`
# by Vercel Cron (vercel.json) when invoking /api/cron/broadcasts every
# 5 min to pick up scheduled broadcasts. Also gates the internal-only
# /api/broadcasts/send-internal endpoint that the cron dispatches to.
# Generate with `openssl rand -hex 32` and set in Vercel project settings.
CRON_SECRET=

# Public API — Week 11
# APP_PEPPER: long random string. Mixed into the SHA-256 hash for every
# API key (stored value = sha256(plaintext + APP_PEPPER)). A leaked DB
# without the pepper still can't validate keys. NEVER rotate this without
# re-issuing every API key in the database — rotation invalidates all
# existing keys. Generate with `openssl rand -base64 32`.
APP_PEPPER=

# XYRA_OPERATOR_ORG_ID: the UUID of YOUR (the Xyra team's) organization.
# Gates the operator admin consoles (/settings/admin/{entitlements,promos,
# disputes,restore,metrics}) + their server actions to owners of THIS org only.
# REQUIRED in production: when unset, the consoles fail CLOSED in prod (nobody
# gets in) and only open to any owner in local dev. Find your org UUID in
# Supabase → organizations table (or it's the org you own). Set it in Vercel
# before launch so customer-org owners can never reach these cross-tenant tools.
XYRA_OPERATOR_ORG_ID=

# Stripe billing — Week 12
# STRIPE_SECRET_KEY: starts with sk_test_ in dev, sk_live_ in production.
#   Stripe Dashboard → Developers → API keys.
# STRIPE_WEBHOOK_SECRET: starts with whsec_. Stripe Dashboard →
#   Developers → Webhooks → click your endpoint → Signing secret.
#   ONE secret per endpoint. Use Stripe CLI for local dev:
#   `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: pk_test_ / pk_live_. Safe to expose
#   to the browser. Only needed if we ever do client-side Stripe.js
#   (we don't today — Checkout + Portal are server-redirected).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs per bundle — fill in after creating products in the
# Stripe Dashboard. Format: price_xxx. Yearly = monthly * 12 * 0.8.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
# Where to send users after they complete checkout. Match your prod URL.
STRIPE_CHECKOUT_SUCCESS_URL=https://xyra-chat.vercel.app/settings/billing?upgraded=true
STRIPE_CHECKOUT_CANCEL_URL=https://xyra-chat.vercel.app/settings/billing

# Rate limiting (Week 15) — Upstash Redis. Create a free DB at upstash.com →
# Redis → REST API. Until BOTH are set, rate limiting FAILS OPEN (no-op), so
# the app works without it; set them to actually enforce the limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error tracking (Week 15) — Sentry. The DSN is public (safe in the browser).
# Until NEXT_PUBLIC_SENTRY_DSN is set, Sentry is inert (no events sent).
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build (CI/release only). SENTRY_AUTH_TOKEN from
# Sentry → Settings → Auth Tokens. Org/project slugs from your Sentry project.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
