# Xyra Chat — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog (EU host for GDPR)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta — WhatsApp Cloud API
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string you choose; you paste this
#   into Meta App Dashboard → WhatsApp → Configuration → Webhook → Verify Token.
# META_APP_SECRET: from Meta App Dashboard → Settings → Basic → App secret.
#   Used for X-Hub-Signature-256 verification on every inbound webhook.
#   Same secret is reused for Instagram + Messenger (same Meta app).
# Channel access tokens are NOT in env — they're stored per-channel in
# Supabase Vault, only the vault UUID lives in channels.access_token_vault_id.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Meta — Instagram DM (Week 5)
#
# Xyra Chat ships with TWO separate Meta apps:
#   - The original Facebook/Meta app for WhatsApp Cloud API
#     (META_APP_SECRET above + future META_APP_ID for WA Embedded Signup)
#   - An Instagram-specific Meta app called "Xyra Chat-IG"
#     (INSTAGRAM_APP_ID + INSTAGRAM_APP_SECRET here)
#
# Webhook + OAuth secrets are NOT shared between the two — each app has its
# own. So `/api/webhooks/instagram` HMACs against INSTAGRAM_APP_SECRET (NOT
# META_APP_SECRET), and the Continue-with-Facebook OAuth uses INSTAGRAM_APP_ID
# + INSTAGRAM_APP_SECRET.
#
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN: any random string you choose; pasted into
#   Meta App Dashboard → (Xyra Chat-IG) → Webhooks → Instagram → Verify Token.
#   Keep distinct from WHATSAPP_WEBHOOK_VERIFY_TOKEN.
# INSTAGRAM_APP_ID / INSTAGRAM_APP_SECRET: Meta App Dashboard → (Xyra Chat-IG)
#   → Settings → Basic. Used for the Continue-with-Facebook OAuth flow AND
#   for verifying X-Hub-Signature-256 on inbound Instagram webhooks.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# META_APP_ID: Meta App Dashboard → (original Meta app) → Settings → Basic
#   → App ID. Reserved for future WhatsApp Embedded Signup (Week 9). Not
#   used today.
META_APP_ID=

# Email (Resend Inbound + outbound) — Week 6
# RESEND_API_KEY: Resend Dashboard → API Keys. Used for BOTH inbound
#   webhook verification (looking up the workspace) and outbound sends.
# RESEND_WEBHOOK_SECRET: Resend Dashboard → Webhooks → (your inbound webhook)
#   → Signing Secret. Comes in `whsec_<base64>` form. We strip the prefix
#   and HMAC-SHA256 against the Svix-format signature header.
# INBOUND_EMAIL_DOMAIN: domain customers email — e.g. `mail.xyrachat.com`.
#   Must be a Resend-verified domain with MX records pointing at Resend.
#   Each Email channel gets a local-part on this domain (e.g.
#   `<slug>@mail.xyrachat.com`).
# EMAIL_FROM_ADDRESS: optional fallback `From:` for outbound when an Email
#   channel doesn't have its own inbox_email. Defaults to
#   `support@xyrachat.com` in code.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=mail.xyrachat.com
EMAIL_FROM_ADDRESS=support@xyrachat.com

# AI — Week 7
# ANTHROPIC_API_KEY: Anthropic Console → API Keys. Used for:
#   - Bot chat replies (claude-sonnet-4-6) via /api/ai/suggest-reply +
#     webhook bot-gate
#   - Message Assist rewrites (claude-haiku-4-5-20251001) via
#     /api/ai/message-assist
#   - Translate-inbound + auto-translate (claude-haiku)
# OPENAI_API_KEY: OpenAI Dashboard → API Keys. Used for:
#   - Embeddings for the RAG knowledge base
#     (text-embedding-3-small, 1536 dims — must match vector(1536)
#     in migration 016)
#   - Future: Whisper voice-note transcription (whisper-1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Broadcasts — Week 9
# CRON_SECRET: long random string. Sent as `Authorization: Bearer <value>`
# by Vercel Cron (vercel.json) when invoking /api/cron/broadcasts every
# 5 min to pick up scheduled broadcasts. Also gates the internal-only
# /api/broadcasts/send-internal endpoint that the cron dispatches to.
# Generate with `openssl rand -hex 32` and set in Vercel project settings.
CRON_SECRET=

# Public API — Week 11
# APP_PEPPER: long random string. Mixed into the SHA-256 hash for every
# API key (stored value = sha256(plaintext + APP_PEPPER)). A leaked DB
# without the pepper still can't validate keys. NEVER rotate this without
# re-issuing every API key in the database — rotation invalidates all
# existing keys. Generate with `openssl rand -base64 32`.
APP_PEPPER=
